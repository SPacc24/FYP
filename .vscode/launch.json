{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run AutoPenTest Recon Flask App",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/project/app.py",
      "cwd": "${workspaceFolder}/project",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "DEBUG": "true"
      }
    },
    {
      "name": "Check External Recon Tools",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/project/scripts/check_tooling.py",
      "cwd": "${workspaceFolder}/project",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
