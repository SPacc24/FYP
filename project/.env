# Flask dashboard settings.
SECRET_KEY=change-me
DEBUG=false
APP_HOST=0.0.0.0
PORT=5000

# CALDERA settings.
# CALDERA_URL is local because the Flask app talks to CALDERA on Kali.
CALDERA_URL=http://127.0.0.1:8888
CALDERA_API_KEY=redadmin
AGENT_GROUP=red
# KALI_IP is used inside generated Sandcat deploy commands.
KALI_IP=CHANGE-THIS-TO-YOUR-KALI-IP
OPERATION_TIMEOUT=180

# Ollama settings.
# You may set only the base URL; the app adds /api/generate automatically.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT=45
OLLAMA_PLANNER_TIMEOUT=90

# MySQL is optional. The app still runs if MySQL is not installed/reachable.
MYSQL_HOST=127.0.0.1
MYSQL_USER=autopentest
MYSQL_PASS=Admin123#@!
MYSQL_DB=autopentest

# Optional scan modules. Keep disabled unless your lab needs them.
ENABLE_CONTEXT_FOOTPRINTING=0
ENABLE_ARP_SCAN=0
ENABLE_HTTPX=0
ENABLE_DEEP_WEB_DISCOVERY=0
ENABLE_SMBMAP=0
ENABLE_HYDRA=0
GOBUSTER_WORDLIST=/usr/share/wordlists/dirbuster/directory-list-2.3-medium.txt
HYDRA_CREDENTIAL_FILE=
MITRE_CVE_REPO=https://github.com/CVEProject/cvelistV5.git
