  "environment_context_model": {
    "nmap_syn_top_ports": [
      "firewall denied/allowed connection bursts",
      "IDS scan heuristics",
      "NetFlow fan-out"
    ],
    "nmap_banner_intensity0": [
      "service banner grabs",
      "unusual protocol negotiation"
    ],
    "nmap_nse_scripts": [
      "script-specific protocol requests",
      "Windows/RPC/SMB security logs when applicable"
    ],
    "httpx_technology_probe": [
      "web access logs",
      "WAF request metadata"
    ],
    "html_form_parser": [
      "web access logs for one GET/HEAD request"
    ],
    "credential_validation": [
      "authentication failures; disabled from recon"
    ],
    "passive_dns": [
      "DNS resolver queries",
      "internal recursive resolver logs when applicable"
    ],
    "passive_tls": [
      "single TLS handshake metadata",
      "firewall connection log for TLS endpoint when endpoint is contacted"
    ],
    "certificate_transparency": [
      "public CT service query logs; target infrastructure is not contacted"
    ],
    "ldap_rootdse": [
      "LDAP bind/rootDSE query logs",
      "domain controller network logs"
    ],
    "kerberos_info": [
      "Kerberos service contact",
      "KDC/network logs"
    ],
    "tls_cipher_validation": [
      "multiple TLS handshakes",
      "firewall TLS connection logs"
    ],
    "rdp_negotiation": [
      "RDP negotiation event visibility",
      "firewall connection logs"
    ],
    "targeted_web_discovery": [
      "web access logs for a small known-path set",
      "WAF metadata"
    ],
    "api_discovery": [
      "web access logs for documentation/schema paths",
      "WAF metadata"
    ],
    "kubernetes_exposure": [
      "Kubernetes API/server access logs if exposed",
      "firewall logs"
    ],
    "container_exposure": [
      "Docker/registry API access logs if exposed",
      "firewall logs"
    ],
    "vpn_validation": [
      "VPN portal web logs",
      "firewall TLS connection logs"
    ],
    "nuclei_safe": [
      "web access logs from safe template requests",
      "WAF metadata"
    ],
    "passive_packet_inventory": [
      "No target probes generated; may be visible only as local packet capture process on scanner host."
    ],
    "passive_os_fingerprinting": [
      "No target probes generated; passive OS hints from ambient traffic only."
    ],
    "native_protocol_enrichment": [
      "single bounded protocol metadata connection per observed service",
      "application logs may record one connection/banner interaction"
    ],
    "postgres_readiness_native": [
      "single PostgreSQL readiness connection",
      "database listener log if configured"
    ]
  },
  "active_validation_guardrails": {
    "description": "Modern active validation is evidence-only and budgeted. It must not perform exploitation, credential use, brute force, payload injection, or post-exploitation.",
    "require_observed_service_before_validation": true,
    "approval_gated_collectors": [
      "ldap_rootdse",
      "kerberos_info",
      "rdp_negotiation",
      "nuclei_safe"
    ],
    "native_http_collectors": [
