        "indicators": [
          "protection.outlook.com",
          "spf.protection.outlook.com",
          "outlook.com"
        ]
      },
      "Google Workspace": {
        "indicators": [
          "aspmx.l.google.com",
          "_spf.google.com",
          "google.com"
